{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "docker: pull acl2 image",
            "type": "shell",
            "command": "docker pull atwalter/acl2:latest",
            "problemMatcher": []
        },
        {
            "label": "docker: start acl2 shell",
            "type": "shell",
            "command": "docker compose run --rm acl2",
            "problemMatcher": []
        },
        {
            "label": "acl2: certify all books",
            "type": "shell",
            "command": ".\\scripts\\certify_all.ps1",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "acl2: certify core (Layer 0)",
            "type": "shell",
            "command": "echo '(certify-book \"hb1384_core\" ?)' | docker run --rm -i -v \"${workspaceFolder}:/work\" -w /work atwalter/acl2:latest acl2",
            "problemMatcher": []
        },
        {
            "label": "acl2: certify process (Layer 0)",
            "type": "shell",
            "command": "echo '(certify-book \"hb1384_process\" ?)' | docker run --rm -i -v \"${workspaceFolder}:/work\" -w /work atwalter/acl2:latest acl2",
            "problemMatcher": []
        },
        {
            "label": "acl2: certify process_invariants (Layer 0)",
            "type": "shell",
            "command": "echo '(certify-book \"hb1384_process_invariants\" ?)' | docker run --rm -i -v \"${workspaceFolder}:/work\" -w /work atwalter/acl2:latest acl2",
            "problemMatcher": []
        },
        {
            "label": "acl2: certify consistency_check (Layer 0)",
            "type": "shell",
            "command": "echo '(certify-book \"hb1384_consistency_check\" ?)' | docker run --rm -i -v \"${workspaceFolder}:/work\" -w /work atwalter/acl2:latest acl2",
            "problemMatcher": []
        },
        {
            "label": "acl2: certify facts (Layer 1)",
            "type": "shell",
            "command": "echo '(certify-book \"hb1384_facts\" ? nil :defaxioms-okp t)' | docker run --rm -i -v \"${workspaceFolder}:/work\" -w /work atwalter/acl2:latest acl2",
            "problemMatcher": []
        },
        {
            "label": "acl2: certify challenger_model (Layer 3)",
            "type": "shell",
            "command": "echo '(certify-book \"hb1384_challenger_model\" ? nil :defaxioms-okp t)' | docker run --rm -i -v \"${workspaceFolder}:/work\" -w /work atwalter/acl2:latest acl2",
            "problemMatcher": []
        },
        {
            "label": "acl2: certify commonwealth_model (Layer 3)",
            "type": "shell",
            "command": "echo '(certify-book \"hb1384_commonwealth_model\" ? nil :defaxioms-okp t)' | docker run --rm -i -v \"${workspaceFolder}:/work\" -w /work atwalter/acl2:latest acl2",
            "problemMatcher": []
        },
        {
            "label": "validate: run trace validator",
            "type": "shell",
            "command": "python tools\\validate_trace.py",
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "clean: remove build artifacts",
            "type": "shell",
            "command": "Remove-Item *.cert, *.fasl, *.port, *@expansion.lsp -ErrorAction SilentlyContinue",
            "problemMatcher": []
        }
    ]
}